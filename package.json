{
  "name": "medicare-clinic",
  "version": "1.0.0",
  "description": "MediCare Clinic Appointment System",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "dev": "nodemon server.js",
    "desktop": "electron .",
    "package": "electron-packager . MediCare --platform=win32 --arch=x64 --out=dist --overwrite",
    "package:win": "electron-packager . MediCare --platform=win32 --arch=x64 --out=dist --overwrite",
    "build:web": "node scripts/build-web.js",
    "mobile:init": "npx cap init medicare com.medicare.app --web-dir=www",
    "mobile:add:android": "npx cap add android",
    "mobile:add:ios": "npx cap add ios",
    "mobile:copy": "npx cap copy",
    "mobile:sync": "npx cap sync",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^5.7.8",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/android": "^5.7.8",
    "@capacitor/cli": "^5.7.8",
    "@capacitor/ios": "^5.0.0",
    "electron": "^26.0.0",
    "electron-packager": "^17.1.0"
  }
}
